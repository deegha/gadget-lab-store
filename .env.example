# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gadgetlab

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars

# ── Admin account (seeded on first boot) ─────────────────────────────────────
ADMIN_EMAIL=deegha@codewavelabs.io
ADMIN_PASSWORD=Steamboat

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=gadgetlab-images
MINIO_USE_SSL=false

# ── Mailtrap ──────────────────────────────────────────────────────────────────
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=
MAILTRAP_PASS=

# ── CORS (comma-separated origins) ───────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# ── Next.js (storefront + admin) ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
INTERNAL_API_URL=http://api:3001
